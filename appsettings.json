{
  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=FacialRecognitionDb;Trusted_Connection=true;TrustServerCertificate=true;MultipleActiveResultSets=true"
  },

  "Cloudinary": {
    "CloudName": "YOUR_CLOUD_NAME",
    "ApiKey": "YOUR_API_KEY",
    "ApiSecret": "YOUR_API_SECRET",
    "UploadFolder": "facial-attendance/employees"
  },

  "EncryptionSettings": {
    "AesKey": "CHANGE_ME_BASE64_32BYTES_KEY_HERE_AAAAAAAAAA=="
  },

  "FaceRecognition": {
    "DetectionModelPath": "OnnxModels/face_detection.onnx",
    "RecognitionModelPath": "OnnxModels/face_recognition.onnx",
    "VerificationThreshold": 0.45,
    "DetectionConfidenceThreshold": 0.7,
    "DetectionInputWidth": 640,
    "DetectionInputHeight": 480,
    "RecognitionInputSize": 112,
    "UseDevelopmentMode": false
  },

  "Attendance": {
    "WorkdayStart": "09:00",
    "GraceMinutes": 15,
    "HalfDayThresholdMinutes": 120,
    "WorkdayEnd": "17:00"
  },

  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },

  "AllowedHosts": "*"
}
